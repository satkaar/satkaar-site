organization_id = "11111111-1111-1111-1111-111111111111"
project_id      = "22222222-2222-2222-2222-222222222222"
# Set only if your DNS zone is managed in Scaleway Domains.
dns_project_id  = "33333333-3333-3333-3333-333333333333"

region = "fr-par"

container_namespace_name = "satkaar-prod"
container_name           = "website-prod"
registry_namespace       = "satkaar-prod"
image_name               = "website"
image_tag                = "latest"

port            = 3000
cpu_limit       = 1000
memory_limit    = 2048
min_scale       = 0
max_scale       = 3
max_concurrency = 80
timeout         = 300

domain_zone   = "satkaar.io"
domain_record = "@"
domain_record_type = "ALIAS"
manage_dns_record = false
